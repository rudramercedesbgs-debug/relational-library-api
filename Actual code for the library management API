@app.route('/book/add', methods=['POST'])
def add_book():
    incoming_data = request.json
    title = incoming_data.get("title")
    price = incoming_data.get("price")
    author_id = incoming_data.get("author_id") 
    
    if not title or not price or not author_id:
        return jsonify({"error": "Missing parameters"}), 400
        
    
    conn = sqlite3.connect("library_management.db")
    cursor = conn.cursor()
    cursor.execute("PRAGMA foreign_keys = ON;")
    
    try:
        cursor.execute("""
            INSERT INTO books (title, price, author_id)
            VALUES (?, ?, ?)
        """, (title, price, author_id))
        conn.commit()
        return jsonify({"status": "Success", "message": "Book saved successfully"}), 201
    except sqlite3.IntegrityError:
        # Enforces foreign key constraint checks
        return jsonify({"error": "Foreign Key violation. That author_id does not exist."}), 400
    finally:
        conn.close()

if __name__ == "__main__":
    app.run(debug=True)
